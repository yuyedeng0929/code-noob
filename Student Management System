#include<iostream>
#include<string>
#include<vector>
#include<algorithm>
#include<iomanip>
using namespace std;

struct Student {    //Create Student Structure
    string name;
    int score;
    int id;
};

bool isIDExist(vector<Student>& list,int id){    //Check if the ID is duplicated
    for(auto &s : list){
        if(s.id == id) return true;
    }
    return false;
}

bool cmpStudentdesc(Student a, Student b) {    //Sort by score in descending order
    return a.score > b.score;
}

bool cmpStudentasc(Student a,Student b){    //Sort by score in ascending order
    return a.score < b.score;
}

bool cmpID(Student a,Student b){    //Sort by ID
    return a.id < b.id;
}

bool cmpName(Student a,Student b){    //Sort by name
    return a.name < b.name;
}

int main() {
    vector<Student> stuList;
    int option = 0;

    while(true){
        cout << "====== Student Management System ======" << endl;
        cout << "1. Add" << endl;
        cout << "2. Display" << endl;
        cout << "3. Sort" << endl;
        cout << "4. Search by student ID" << endl;
        cout << "5. Modify score" << endl;
        cout << "6. Delete student" << endl;
        cout << "7. Count failing students" << endl;
        cout << "8. Clear all" << endl;
        cout << "9. Score Statistics (avg/max/min)" << endl;
        cout << "10. Score Range (90-100 etc.)" << endl;
        cout << "11. Fuzzy search by name" << endl;
        cout << "12. Page display" << endl;
        cout << "0. Exit" << endl;
        cout << "========================================" << endl;
        cout << "Please enter your option: " << endl;

        if(!(cin >> option)){    //Prevent crashes caused by non-numeric input
            cin.clear();
            cin.ignore(10000,'\n');
            cout << "Input contains non-numeric characters. Please enter again." << endl;
            continue;
        }

        if(option == 0){    // 0. Exit
            cout << "You have exited the system." << endl;
            break;
        }

        if(option == 1){    // 1. Add
            Student stu;
            cout << "Please enter the name: "; cin >> stu.name;
            cout << "Please enter the id: "; cin >> stu.id;
            if(isIDExist(stuList,stu.id)){    //Check if the id duplicated
                cout << "The id is duplicated.Please enter again." << endl;
                continue;
            }
            cout << "Please enter the score: "; cin >> stu.score;
            if(stu.score < 0 || stu.score > 100){    //Check whether the input score is reasonable
                cout << "The score is not reasonable.Please enter the score again." << endl;
                continue;
            }
            stuList.push_back(stu);
            cout << "You have added a new student successfully!" << endl;
        }

        if(option == 2){    // 2. Display
            if(stuList.empty()){
                cout << "There is no data for this student." << endl;
            }else{
                cout << "\nName\tID\tScore" << endl;
                for (auto &s : stuList) {
                    cout << s.name << "\t"
                         << s.id << "\t"
                         << s.score << endl;
                }
            }
            cout << endl;
        }

        if(option == 3){    // 3.Multi-condition sorting
            if(stuList.empty()){
                cout << "There is no data for this student." << endl;
            }else{
                int op = 0;
                cout << "Choose the way you want to sort :" << endl
                << "1--score desc 2--score asc 3--by id 4--by name" << endl;
                cin >> op;
                if(op == 1){    //descending
                    sort(stuList.begin(), stuList.end(), cmpStudentdesc);
                    cout << "Sorted by score in descending order successfully!" << endl;
                }
                if(op == 2){    //ascending
                    sort(stuList.begin(),stuList.end(),cmpStudentasc);
                    cout << "Sorted by score in ascending order successfully!" << endl;
                }
                if(op == 3){    //id
                    sort(stuList.begin(),stuList.end(),cmpID);
                    cout << "Sorted by id order successfully!" << endl;
                }
                if(op == 4){    //name
                    sort(stuList.begin(),stuList.end(),cmpName);
                    cout << "Sorted by name order successfully!" << endl;
                }
            }
        }

        if(option == 4){    // 4. Search by student ID
            if(stuList.empty()){
                cout << "There is no data for this student." << endl;
            }else{
                int findID = 0;
                cout << "Please enter the student ID to search: ";
                cin >> findID;
                bool found = false;
    
                for (auto &s : stuList) {
                    if (s.id == findID) {
                        cout << "Student ID: " << s.id << endl;
                        cout << "Student name: " << s.name << endl;
                        cout << "Student score: " << s.score << endl;
                        found = true;
                        break;
                    }
                }

                if (!found) {
                    cout << "No such student found!" << endl;
                }
            }
        }

        if(option == 5){    // 5. Modify score
            if(stuList.empty()){
                cout << "There is no data for this student." << endl;
            }else{
                int modifyID = 0;
                cout << "Please enter the student ID to modify: "; cin >> modifyID;
                bool found = false;
    
                for (auto &s : stuList) {
                    if (s.id == modifyID) {
                        cout << "Original Score: " << s.score << endl;
                        cout << "Please enter the new score: ";
                        cin >> s.score;
                        if(s.score <0 || s.score >100){
                            cout << "The score is not reasonable.Modify failed." << endl;
                            found = true;
                            break;
                        }
                        cout << "Modified successfully! New score: " << s.score << endl;
                        found = true;
                        break;
                    }
                }
    
                if (!found) {
                    cout << "Modification failed! No such student." << endl;
                }
            }
        }

        if(option == 6){    // 6. Delete student
            if(stuList.empty()){
                cout << "There is no data for this student." << endl;
            }else{
                int deleteID = 0;
                cout << "Please enter the student ID to delete: "; cin >> deleteID;
                bool deleted = false;
                for(auto it = stuList.begin(); it != stuList.end(); it++){
                    if(it->id == deleteID){
                        stuList.erase(it);
                        cout << "Delete successfully!" << endl;
                        deleted = true;
                        break;
                    }
                }
                if(!deleted){
                    cout << "Delete failed! No such student." << endl;
                }
            }
        }

        if(option == 7){    // 7. Count failing students
            if(stuList.empty()){
                cout << "There is no data for this student." << endl;
            }else{
                int cnt = 0;
                for (auto &s : stuList) {
                    if (s.score < 60) {
                        cnt++;
                    }
                }
                cout << "The number of failing students: " << cnt << endl;
            }
        }

        if(option == 8){    // 8. Clear all
            cout << "Are you sure to CLEAR ALL? 0 = Cancel, 1 = Confirm" << endl;
            int op = 0; cin >> op;
            if (op == 1) {
                stuList.clear();
                cout << "Clear all successfully." << endl;
            } else {
                cout << "Canceled successfully." << endl;
            }
        }

        if(option == 9){    //9.find average score, highest score and lowest score
            if(stuList.empty()){
                cout << "There is no student now!" << endl;
            }else{
                int sum = 0;
                int max = stuList[0].score;
                int min = stuList[0].score;
                for(auto &s : stuList){
                    sum += s.score;
                    if(s.score > max) max = s.score;
                    if(s.score < min) min = s.score;
                }
                double avg = (double)sum / stuList.size();
                cout << fixed << setprecision(2);
                cout << "Avg: " << avg << endl;
                cout << "Max: " << max << endl;
                cout << "Min: " << min << endl;
            }
        }

        if(option == 10){    //10.Score range statistics
            if(stuList.empty()){
                cout << "There is no data for this student." << endl;
            }else{
                int a,b,c,d,e;
                a = b = c = d = e = 0;
                for(auto &s : stuList){
                    if(s.score >= 90) a++;
                    else if(s.score >= 80) b++;
                    else if(s.score >= 70) c++;
                    else if(s.score >= 60) d++;
                    else e++;
                }
                cout << "Below are the students belonging to each score range. " << endl;
                cout << "100 - 90:" << a << endl;
                cout << "90 - 80:" << b << endl;
                cout << "80 - 70:" << c << endl;
                cout << "70 - 60:" << d << endl;
                cout << "Below 60:" << e << endl;
            }
        }

        if(option == 11){    //11.Name fuzzy search
            if(stuList.empty()){
                cout << "There is no data for this student." << endl;
            }else{
                string key;
                cout << "Please enter the name :";
                cin >> key;
                bool found = false;
                for(auto &s : stuList){
                    if(s.name.find(key) != string::npos){
                        cout << s.id << " " << s.name << " " << s.score << endl;
                        found = true;
                    }
                }
                if(!found) cout << "No match !" << endl;
            }
        }

        if(option == 12){    //12.Show pages
            if(stuList.empty()){
                cout << "There is no data for this student." << endl;
            }else{
                int pagesize = 3;
                cout << "Please enter the pagesize(default 3) :" << endl;
                cin >> pagesize;
                int total = stuList.size();
                int pages = total / pagesize;
                if(total % pagesize != 0) pages++;
    
                cout << "Total pages :" << pages << endl;
                int page = 0;
                cout << "Please enter the page you want to view :" << endl;
                cin >> page;
    
                int start = (page - 1) * pagesize;
                int end = start + pagesize;
                if(end > total) end = total;
    
                cout << "ID\tName\tScore" << endl;
                for (int i = start; i < end; i++) {
                    cout << stuList[i].id << "\t"
                         << stuList[i].name << "\t"
                         << stuList[i].score << endl;
                }
            }
        }
        cout << endl;
    }
    return 0;
}
