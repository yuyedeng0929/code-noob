#include<iostream>
#include<string>
#define MAX 1000

using namespace std;
//1.set up the contact structure
struct Person{
	//name
	string m_Name;
	//gender
	int m_Gender;
	//age
	int m_Age;
	//phoneNumber
	string m_Phone;
	//address
	string m_Address;
}; 

//set up the address book structure
struct Addressbooks{
	//the array of the contacts in the address book 
	struct Person personArray[MAX];
	//the number of the contacts in the address book
	int m_Size;  
}; 

//2.show the menu
void showMenu(){
	cout << "******************" << endl;
	cout << "***1.Add Contact***" << endl;
	cout << "***2.Show All Contacts***" << endl;
	cout << "***3.Delete Contact***" << endl;
	cout << "***4.Find Contact***" << endl;
	cout << "***5.Modify Contact***" << endl;
	cout << "***6.Clear All Contacts***" << endl;
	cout << "***0.Exit Address Book***" << endl;
	cout << "******************" << endl;
}

void addPerson(Addressbooks * abs){
	if(abs->m_Size == MAX){
		cout << "Address book is full, add failed！" << endl;
	}else{
		//3.add the contact
		
		//name
		string name;
		cout <<"Please enter the name：" << endl;
		cin >> name;
		abs->personArray[abs->m_Size].m_Name = name;
		//gender
		cout << "Please enter the gender：" << endl;
		cout << "1.---Male" << endl;
		cout << "2.---Female" << endl;
		int gender = 0;
		
		while(true){
			cin >> gender;
			if(gender == 1||gender == 2){
				abs->personArray[abs->m_Size].m_Gender = gender;
				break;
			}
			cout << "Invalid input, please try again！" << endl;
		}
		//age
		cout << "Please enter the age：" << endl;
		int age = 0;
		cin >> age;
		abs->personArray[abs->m_Size].m_Age = age;
		//phone number
		cout << "Please enter the phone number：" << endl;
		string phone;
		cin >> phone; 
		abs->personArray[abs->m_Size].m_Phone = phone;
		//address
		cout << "Please enter the home address：" << endl;
		string address;
		cin >> address;
		abs->personArray[abs->m_Size].m_Address = address;
		
		cout << "Added successfully！" << endl;
		abs->m_Size++;
		system("pause");
		system("cls"); 
	
	}
}

//4.show the all contacts
void showPerson(Addressbooks * abs){
	if(abs->m_Size == 0){
		cout <<"Address book is empty" << endl;
	}else{
		for(int i = 0;i<abs->m_Size;i++){
			cout << "Name：" << abs->personArray[i].m_Name << "\t";
			cout << "Gender：" << (abs->personArray[i].m_Gender == 1?"Male":"Female") << "\t";
			cout << "Age：" << abs->personArray[i].m_Age << "\t";
			cout << "Phone：" << abs->personArray[i].m_Phone << "\t";
			cout << "Address：" << abs->personArray[i].m_Address << endl;
		} 
	}
	
	system("pause");
	system("cls");
}

int isExist(Addressbooks * abs,string name){
	for(int i = 0;i<abs->m_Size;i++){
		if(abs->personArray[i].m_Name == name){
			return i;
		}
	}
	return -1;
}

//Delete specified contact
void deletePerson(Addressbooks * abs){
	cout << "Please enter the contact name to delete：" << endl;
	
	string name;
	cin >> name;
	int ret = isExist(abs,name);
	if(ret != -1){
		for(int i = ret;i<abs->m_Size-1;i++){
			abs->personArray[i] = abs->personArray[i+1];
		}
        abs->m_Size--;
		cout << "Deleted successfully！" << endl;
	}
    else{
        cout << "Contact not found" << endl;
    }
	system("pause");
	system("cls");
}

void findPerson(Addressbooks * abs){
	cout << "Please enter the contact name to find：" << endl;
	string name;
	cin >> name;
	int ret = isExist(abs,name);
	if(ret != -1){
		cout << "Name：" << abs->personArray[ret].m_Name << "\t";
		cout << "Gender：" << (abs->personArray[ret].m_Gender == 1?"Male":"Female") << "\t";
		cout << "Age：" << abs->personArray[ret].m_Age << "\t";
		cout << "Phone：" << abs->personArray[ret].m_Phone << "\t";
		cout << "Address：" << abs->personArray[ret].m_Address << endl;
	} else{
		cout << "Contact not found" << endl; 
	}
    system("pause");
    system("cls");
}

//Modify specified contact information
void modifyPerson(Addressbooks * abs){
	cout << "Please enter the contact name to modify：" << endl;
	string name;
	cin >> name;
	int ret = isExist(abs,name);
	if(ret != -1){
		string name;
		cout << "Please enter name：" << endl;
		cin >> name;
		abs->personArray[ret].m_Name = name;
		cout << "Please enter gender：" << endl;
		cout << "1--Male" << endl;
		cout << "2--Female" << endl;
		int gender = 0;
		
		while(true){
			cin >> gender;
			if(gender == 1||gender == 2){
				abs->personArray[ret].m_Gender = gender;
				break;
			}
			cout << "Invalid input, please try again！" << endl;
		}
		
		cout << "Please enter age：" << endl;
		int age = 0;
		cin >> age;
		abs->personArray[ret].m_Age = age;
		
		cout << "Please enter phone：" << endl;
		string phone;
		cin >> phone;
		abs->personArray[ret].m_Phone = phone;

		cout << "Please enter home address：" << endl;
		string address;
		cin >>address;
		abs->personArray[ret].m_Address = address;
		cout << "Modified successfully！" << endl;
	}else{
		cout << "Contact not found" << endl;
	}
	system("pause");
	system("cls");
} 

//Clear all contacts
void cleanPerson(Addressbooks * abs){
	abs->m_Size = 0;
	cout << "Address book cleared successfully" << endl;
	system("pause");
	system("cls");
} 

int main(){
	int select = 0;
	Addressbooks abs;
	abs.m_Size = 0;
	
	while(true){
	showMenu();
	cin >> select;
	switch(select){
		case 1:  //Add Contact 
			addPerson(&abs);
			break;
		case 2:  //Show Contacts 
			showPerson(&abs);
			break;
		case 3:  //Delete Contact 
			deletePerson(&abs);
			break;
		case 4:  //Find Contact
			findPerson(&abs); 
			break;
		case 5:  //Modify Contact 
			modifyPerson(&abs);
			break;
		case 6:  //Clear Contacts 
			cleanPerson(&abs);
			break;
		case 0:  //Exit Address Book 
			cout << "Welcome to use next time" << endl; 
			system("pause");
			return 0;
			break;
		default:
			cout << "Invalid option, please try again" << endl;
            system("pause");
            system("cls");
			break;
		}
	}
	
	system("pause");
	
	return 0;
}

